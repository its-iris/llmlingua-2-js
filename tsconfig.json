{
  "compilerOptions": {
    "target": "es2023",
    "module": "nodenext",
    "rootDir": "./src",
    "moduleResolution": "nodenext",
    "sourceMap": true,
    "outDir": "./dist",
    "esModuleInterop": true,
    "strict": true,
    "skipLibCheck": true,
    "declarationMap": true,
    "declaration": true
  },
  "include": ["src/**/*"]
}
